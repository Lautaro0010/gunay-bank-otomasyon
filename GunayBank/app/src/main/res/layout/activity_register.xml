<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EBF2FC"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Üst bant -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#004794"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Günay Bank"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Yeni Hesap Oluştur"
                android:textColor="#C8DCFF"
                android:textSize="13sp"/>
        </LinearLayout>

        <!-- Bonus notu -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#DCF0DC"
            android:padding="12dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🎁  Kayıt olanlara: 5.000 TL vadesiz + 1.000 TL birikim + 100 $ döviz hesabı açılır!"
                android:textColor="#1E641E"
                android:textSize="12sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Form kartı -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:layout_margin="16dp"
            android:padding="20dp"
            android:elevation="4dp">

            <!-- Ad Soyad -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ad Soyad *"
                android:textColor="#3C3C50"
                android:textSize="13sp"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/etAd"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/et_border"
                android:hint="Adınızı ve soyadınızı giriniz"
                android:inputType="textPersonName"
                android:padding="12dp"
                android:textSize="14sp"
                android:layout_marginBottom="16dp"/>

            <!-- Müşteri No (otomatik) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Müşteri No (Otomatik)"
                android:textColor="#3C3C50"
                android:textSize="13sp"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/tvMusteriNo"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="#EEF2FF"
                android:fontFamily="monospace"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:textColor="#004794"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <!-- Şifre -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Şifre *"
                android:textColor="#3C3C50"
                android:textSize="13sp"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/etSifre"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/et_border"
                android:hint="En az 4 karakter"
                android:inputType="textPassword"
                android:padding="12dp"
                android:textSize="14sp"
                android:layout_marginBottom="16dp"/>

            <!-- Şifre Tekrar -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Şifre Tekrar *"
                android:textColor="#3C3C50"
                android:textSize="13sp"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/etSifre2"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/et_border"
                android:hint="Şifrenizi tekrar giriniz"
                android:inputType="textPassword"
                android:padding="12dp"
                android:textSize="14sp"
                android:layout_marginBottom="16dp"/>

            <!-- E-posta -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="E-posta"
                android:textColor="#3C3C50"
                android:textSize="13sp"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/et_border"
                android:hint="ornek@email.com"
                android:inputType="textEmailAddress"
                android:padding="12dp"
                android:textSize="14sp"
                android:layout_marginBottom="16dp"/>

            <!-- Telefon -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Telefon"
                android:textColor="#3C3C50"
                android:textSize="13sp"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/etTelefon"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/et_border"
                android:hint="05XXXXXXXXX"
                android:inputType="phone"
                android:maxLength="11"
                android:padding="12dp"
                android:textSize="14sp"
                android:layout_marginBottom="24dp"/>

            <!-- Butonlar -->
            <Button
                android:id="@+id/btnKayit"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:backgroundTint="#0099E0"
                android:text="Kayıt Ol"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/tvGeri"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="← Giriş sayfasına dön"
                android:textColor="#0099E0"
                android:textSize="13sp"
                android:clickable="true"
                android:focusable="true"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>