<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#EBF2FC">

    <!-- NAVBAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#004794"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Günay Bank"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvHosgeldin"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:gravity="center"
            android:textColor="#C8DCFF"
            android:textSize="12sp"
            android:ellipsize="end"
            android:maxLines="1"/>

        <Button
            android:id="@+id/btnCikis"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:backgroundTint="#C82828"
            android:text="Çıkış"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- ALT NAVİGASYON -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#003070"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnNavAnaSayfa"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:text="🏠 Ana"
            android:textColor="#FFFFFF"
            android:textSize="11sp"/>

        <Button
            android:id="@+id/btnNavBakiye"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:text="💳 Bakiye"
            android:textColor="#FFFFFF"
            android:textSize="11sp"/>

        <Button
            android:id="@+id/btnNavTransfer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:text="💸 Transfer"
            android:textColor="#FFFFFF"
            android:textSize="11sp"/>

        <Button
            android:id="@+id/btnNavProfil"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:text="👤 Profil"
            android:textColor="#FFFFFF"
            android:textSize="11sp"/>
    </LinearLayout>

    <!-- İÇERİK -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ══ ANA SAYFA PANELİ ══ -->
            <LinearLayout
                android:id="@+id/panelAnaSayfa"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ana Sayfa"
                    android:textColor="#004794"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <!-- Vadesiz -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FFFFFF"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:elevation="2dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💳  Vadesiz Hesap"
                        android:textColor="#505080"
                        android:textSize="13sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvAnaSayfaVadesiz"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#008C3C"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>

                <!-- Birikim -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FFFFFF"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:elevation="2dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💰  Birikim Hesabı"
                        android:textColor="#505080"
                        android:textSize="13sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvAnaSayfaBirikim"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#008C3C"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>

                <!-- Döviz -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FFFFFF"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:elevation="2dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💵  Döviz Hesabı"
                        android:textColor="#505080"
                        android:textSize="13sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvAnaSayfaDoviz"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#008C3C"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>

                <!-- Son İşlemler -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Son İşlemler"
                    android:textColor="#004794"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FFFFFF"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:layout_marginBottom="4dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Hoş Geldin Bonusu"
                        android:textSize="13sp" android:textColor="#1A1A2E"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="+ ₺ 5.000,00" android:textColor="#008C3C" android:textStyle="bold" android:textSize="13sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#F5F8FF"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:layout_marginBottom="4dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Birikim Hesabı Açıldı"
                        android:textSize="13sp" android:textColor="#1A1A2E"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="+ ₺ 1.000,00" android:textColor="#008C3C" android:textStyle="bold" android:textSize="13sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FFFFFF"
                    android:orientation="horizontal"
                    android:padding="14dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Döviz Hesabı Açıldı"
                        android:textSize="13sp" android:textColor="#1A1A2E"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="+ $ 100,00" android:textColor="#008C3C" android:textStyle="bold" android:textSize="13sp"/>
                </LinearLayout>

            </LinearLayout>

            <!-- ══ BAKİYE PANELİ ══ -->
            <LinearLayout
                android:id="@+id/panelBakiye"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hesap Bakiyesi"
                    android:textColor="#004794"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <!-- Vadesiz kart -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:background="#FFFFFF" android:orientation="vertical" android:padding="18dp"
                    android:elevation="2dp" android:layout_marginBottom="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="💳 Vadesiz Hesap" android:textColor="#004794" android:textSize="15sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="TL Hesabı" android:textColor="#888888" android:textSize="12sp" android:layout_marginTop="2dp"/>
                    <TextView android:id="@+id/tvBakiyeVadesiz" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="#008C3C"
                        android:textSize="26sp" android:textStyle="bold" android:layout_marginTop="10dp"/>
                </LinearLayout>

                <!-- Birikim kart -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:background="#FFFFFF" android:orientation="vertical" android:padding="18dp"
                    android:elevation="2dp" android:layout_marginBottom="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="💰 Birikim Hesabı" android:textColor="#004794" android:textSize="15sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="TL Hesabı" android:textColor="#888888" android:textSize="12sp" android:layout_marginTop="2dp"/>
                    <TextView android:id="@+id/tvBakiyeBirikim" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="#008C3C"
                        android:textSize="26sp" android:textStyle="bold" android:layout_marginTop="10dp"/>
                </LinearLayout>

                <!-- Döviz kart -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:background="#FFFFFF" android:orientation="vertical" android:padding="18dp"
                    android:elevation="2dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="💵 Döviz Hesabı" android:textColor="#004794" android:textSize="15sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="USD Hesabı" android:textColor="#888888" android:textSize="12sp" android:layout_marginTop="2dp"/>
                    <TextView android:id="@+id/tvBakiyeDoviz" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="#008C3C"
                        android:textSize="26sp" android:textStyle="bold" android:layout_marginTop="10dp"/>
                </LinearLayout>

            </LinearLayout>

            <!-- ══ TRANSFERİ PANELİ ══ -->
            <LinearLayout
                android:id="@+id/panelTransfer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Para Transferi"
                    android:textColor="#004794"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:background="#FFFFFF" android:orientation="vertical" android:padding="20dp" android:elevation="2dp">

                    <TextView android:id="@+id/tvTransferMevcut" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="#008C3C"
                        android:textSize="14sp" android:textStyle="bold" android:layout_marginBottom="16dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Alıcı Ad Soyad" android:textColor="#3C3C50" android:textSize="13sp" android:layout_marginBottom="6dp"/>
                    <EditText android:id="@+id/etAliciAd" android:layout_width="match_parent"
                        android:layout_height="48dp" android:background="@drawable/et_border"
                        android:hint="Alıcının adı soyadı" android:inputType="textPersonName"
                        android:padding="12dp" android:textSize="14sp" android:layout_marginBottom="14dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Alıcı IBAN" android:textColor="#3C3C50" android:textSize="13sp" android:layout_marginBottom="6dp"/>
                    <EditText android:id="@+id/etAliciIban" android:layout_width="match_parent"
                        android:layout_height="48dp" android:background="@drawable/et_border"
                        android:hint="TR00 0000 0000 0000 0000 00" android:inputType="text"
                        android:padding="12dp" android:textSize="14sp" android:layout_marginBottom="14dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Tutar (₺)" android:textColor="#3C3C50" android:textSize="13sp" android:layout_marginBottom="6dp"/>
                    <EditText android:id="@+id/etTutar" android:layout_width="match_parent"
                        android:layout_height="48dp" android:background="@drawable/et_border"
                        android:hint="0.00" android:inputType="numberDecimal"
                        android:padding="12dp" android:textSize="14sp" android:layout_marginBottom="14dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Açıklama" android:textColor="#3C3C50" android:textSize="13sp" android:layout_marginBottom="6dp"/>
                    <EditText android:id="@+id/etAciklama" android:layout_width="match_parent"
                        android:layout_height="48dp" android:background="@drawable/et_border"
                        android:hint="İsteğe bağlı" android:inputType="text"
                        android:padding="12dp" android:textSize="14sp" android:layout_marginBottom="20dp"/>

                    <Button android:id="@+id/btnGonder" android:layout_width="match_parent"
                        android:layout_height="50dp" android:backgroundTint="#0099E0"
                        android:text="💸  Gönder" android:textColor="#FFFFFF"
                        android:textSize="15sp" android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ══ PROFİL PANELİ ══ -->
            <LinearLayout
                android:id="@+id/panelProfil"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Profil Bilgileri"
                    android:textColor="#004794"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:background="#FFFFFF" android:orientation="vertical"
                    android:padding="20dp" android:elevation="2dp">

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="👤" android:textSize="40sp" android:gravity="center"
                        android:layout_marginBottom="16dp"/>

                    <!-- Profil satırları -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Ad Soyad" android:textColor="#6478A0" android:textSize="12sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/tvProfilAd" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="#1A1A2E"
                        android:textSize="15sp" android:layout_marginBottom="14dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Müşteri No" android:textColor="#6478A0" android:textSize="12sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/tvProfilNo" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="#1A1A2E"
                        android:textSize="15sp" android:fontFamily="monospace" android:layout_marginBottom="14dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="E-posta" android:textColor="#6478A0" android:textSize="12sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/tvProfilEmail" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="#1A1A2E"
                        android:textSize="15sp" android:layout_marginBottom="14dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Telefon" android:textColor="#6478A0" android:textSize="12sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/tvProfilTel" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="#1A1A2E"
                        android:textSize="15sp" android:layout_marginBottom="14dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Kayıt Tarihi" android:textColor="#6478A0" android:textSize="12sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/tvProfilTarih" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="#1A1A2E"
                        android:textSize="15sp" android:layout_marginBottom="14dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Toplam Varlık (TL)" android:textColor="#6478A0" android:textSize="12sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/tvProfilToplam" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="#008C3C"
                        android:textSize="18sp" android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>