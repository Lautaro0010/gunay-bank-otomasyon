<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#EBF2FC">

    <!-- NAVBAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#500000"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Günay Bank  |  Yönetici Paneli"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👑 Admin"
            android:textColor="#FFD296"
            android:textSize="13sp"
            android:layout_marginEnd="12dp"/>

        <Button
            android:id="@+id/btnCikis"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:backgroundTint="#A01E1E"
            android:text="Çıkış"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- ALT NAV -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#3C0000"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnNavGenel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:text="📊 Genel"
            android:textColor="#FFFFFF"
            android:textSize="12sp"/>

        <Button
            android:id="@+id/btnNavKullanicilar"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:text="👥 Kullanıcılar"
            android:textColor="#FFFFFF"
            android:textSize="12sp"/>

        <Button
            android:id="@+id/btnNavEkle"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:text="➕ Ekle"
            android:textColor="#FFFFFF"
            android:textSize="12sp"/>
    </LinearLayout>

    <!-- İÇERİK -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ══ GENEL BAKIŞ ══ -->
            <LinearLayout
                android:id="@+id/panelGenel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Genel Bakış"
                    android:textColor="#640000"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <!-- Kart: Toplam Kullanıcı -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:background="#FFFFFF" android:orientation="vertical" android:padding="20dp"
                    android:elevation="2dp" android:layout_marginBottom="12dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="👥  Toplam Kullanıcı" android:textColor="#783C3C"
                        android:textSize="13sp" android:textStyle="bold"/>

                    <TextView android:id="@+id/tvToplamKullanici" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="#500000"
                        android:textSize="32sp" android:textStyle="bold" android:layout_marginTop="8dp"/>
                </LinearLayout>

                <!-- Kart: Banka Adı -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:background="#FFFFFF" android:orientation="vertical" android:padding="20dp"
                    android:elevation="2dp" android:layout_marginBottom="12dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🏦  Banka Adı" android:textColor="#783C3C"
                        android:textSize="13sp" android:textStyle="bold"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Günay Bank" android:textColor="#500000"
                        android:textSize="22sp" android:textStyle="bold" android:layout_marginTop="8dp"/>
                </LinearLayout>

            </LinearLayout>

            <!-- ══ KULLANICILAR ══ -->
            <LinearLayout
                android:id="@+id/panelKullanicilar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tüm Kullanıcılar"
                    android:textColor="#640000"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:id="@+id/llKullaniciListesi"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

            </LinearLayout>

            <!-- ══ KULLANICI EKLE ══ -->
            <LinearLayout
                android:id="@+id/panelEkle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kullanıcı Ekle"
                    android:textColor="#640000"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:background="#FFFFFF" android:orientation="vertical"
                    android:padding="20dp" android:elevation="2dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Ad Soyad *" android:textColor="#503028" android:textSize="13sp" android:layout_marginBottom="6dp"/>
                    <EditText android:id="@+id/etAd" android:layout_width="match_parent"
                        android:layout_height="48dp" android:background="@drawable/et_border"
                        android:hint="Ad ve soyad giriniz" android:inputType="textPersonName"
                        android:padding="12dp" android:textSize="14sp" android:layout_marginBottom="14dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Şifre *" android:textColor="#503028" android:textSize="13sp" android:layout_marginBottom="6dp"/>
                    <EditText android:id="@+id/etSifre" android:layout_width="match_parent"
                        android:layout_height="48dp" android:background="@drawable/et_border"
                        android:hint="Şifre giriniz" android:inputType="textPassword"
                        android:padding="12dp" android:textSize="14sp" android:layout_marginBottom="14dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="E-posta" android:textColor="#503028" android:textSize="13sp" android:layout_marginBottom="6dp"/>
                    <EditText android:id="@+id/etEmail" android:layout_width="match_parent"
                        android:layout_height="48dp" android:background="@drawable/et_border"
                        android:hint="ornek@email.com" android:inputType="textEmailAddress"
                        android:padding="12dp" android:textSize="14sp" android:layout_marginBottom="14dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Telefon" android:textColor="#503028" android:textSize="13sp" android:layout_marginBottom="6dp"/>
                    <EditText android:id="@+id/etTelefon" android:layout_width="match_parent"
                        android:layout_height="48dp" android:background="@drawable/et_border"
                        android:hint="05XXXXXXXXX" android:inputType="phone"
                        android:padding="12dp" android:textSize="14sp" android:layout_marginBottom="20dp"/>

                    <Button android:id="@+id/btnEkle" android:layout_width="match_parent"
                        android:layout_height="50dp" android:backgroundTint="#B41E1E"
                        android:text="Ekle" android:textColor="#FFFFFF"
                        android:textSize="15sp" android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>